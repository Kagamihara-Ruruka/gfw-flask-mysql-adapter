{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/common-adapter/runtime-config.schema.json",
  "title": "RRKAL runtime config",
  "type": "object",
  "required": ["schema", "role", "query_policy", "server"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "rrkal.adapter.runtime_json.v1"
    },
    "role": {
      "const": "runtime_json"
    },
    "description": {
      "type": "string"
    },
    "runtime_profile": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "managed_by": { "type": "string", "minLength": 1 },
        "manifest_path": { "type": "string", "minLength": 1 },
        "mapping_path": { "type": "string", "minLength": 1 }
      }
    },
    "query_policy": {
      "type": "object",
      "required": [
        "default_limit",
        "max_limit",
        "table_preview_limit",
        "require_time_or_bbox_filter"
      ],
      "additionalProperties": false,
      "properties": {
        "default_limit": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        },
        "max_limit": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        },
        "table_preview_limit": {
          "type": "integer",
          "minimum": 1
        },
        "require_time_or_bbox_filter": {
          "type": "boolean"
        },
        "network_concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 6
        },
        "background_network_concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 3
        },
        "batch_max_operations": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32,
          "default": 3
        },
        "batch_gzip_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9,
          "default": 3
        },
        "snapshot_cache_max_rows": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ],
          "default": 800000
        }
      }
    },
    "server": {
      "type": "object",
      "required": ["default_command", "host", "port", "debug", "kill_port_if_busy"],
      "additionalProperties": false,
      "properties": {
        "default_command": { "const": "serve" },
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "debug": { "type": "boolean" },
        "kill_port_if_busy": { "type": "boolean" }
      }
    },
    "playback": {
      "type": "object",
      "additionalProperties": false,
      "required": ["buffer_unit", "low_watermark_months", "high_watermark_months"],
      "properties": {
        "buffer_unit": {
          "type": "string",
          "enum": ["frame", "calendar_month"]
        },
        "low_watermark_months": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "high_watermark_months": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "rated_frame_bytes": {
          "type": "integer",
          "minimum": 1048576
        },
        "cache_headroom_frames": {
          "type": "integer",
          "minimum": 0,
          "maximum": 62
        },
        "cache_max_bytes": {
          "type": "integer",
          "minimum": 67108864
        }
      }
    },
    "rendering": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "hardware_acceleration": {
          "type": "string",
          "enum": ["auto", "webgl", "canvas"]
        },
        "allow_webgl": { "type": "boolean" },
        "allow_webgpu": { "type": "boolean" },
        "min_webgl_rows": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
