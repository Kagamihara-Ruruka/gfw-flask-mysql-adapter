{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/common-adapter/runtime-config.schema.json",
  "title": "RRKAL runtime config",
  "type": "object",
  "required": ["schema", "role", "query_policy", "server"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "const": "rrkal.adapter.runtime_json.v1"
    },
    "role": {
      "const": "runtime_json"
    },
    "description": {
      "type": "string"
    },
    "query_policy": {
      "type": "object",
      "required": [
        "default_limit",
        "max_limit",
        "table_preview_limit",
        "require_time_or_bbox_filter"
      ],
      "additionalProperties": false,
      "properties": {
        "default_limit": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        },
        "max_limit": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        },
        "table_preview_limit": {
          "type": "integer",
          "minimum": 1
        },
        "require_time_or_bbox_filter": {
          "type": "boolean"
        },
        "network_concurrency": {
          "type": "integer",
          "minimum": 1,
          "maximum": 16,
          "default": 6
        },
        "snapshot_cache_max_rows": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ],
          "default": 800000
        }
      }
    },
    "server": {
      "type": "object",
      "required": ["default_command", "host", "port", "debug", "kill_port_if_busy"],
      "additionalProperties": false,
      "properties": {
        "default_command": { "const": "serve" },
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "debug": { "type": "boolean" },
        "kill_port_if_busy": { "type": "boolean" }
      }
    },
    "rendering": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "hardware_acceleration": {
          "type": "string",
          "enum": ["auto", "webgl", "canvas"]
        },
        "allow_webgl": { "type": "boolean" },
        "allow_webgpu": { "type": "boolean" },
        "min_webgl_rows": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
