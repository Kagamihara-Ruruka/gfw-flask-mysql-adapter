{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/gfw-mysql-adapter/config.schema.json",
  "title": "GFW Flask adapter config",
  "type": "object",
  "required": ["sql_backend", "mysql", "query_policy", "server", "default_dataset", "datasets"],
  "additionalProperties": false,
  "properties": {
    "sql_backend": {
      "type": "object",
      "required": ["kind", "driver"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["mysql", "hive"]
        },
        "driver": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "mysql": {
      "type": "object",
      "required": ["host", "port", "user", "password", "database"],
      "additionalProperties": false,
      "properties": {
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "user": { "type": "string", "minLength": 1 },
        "password": { "type": "string" },
        "database": { "$ref": "#/$defs/sqlIdentifier" }
      }
    },
    "default_connection_ref": {
      "$ref": "#/$defs/sqlIdentifier"
    },
    "connections": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["kind", "driver", "host", "port", "user", "password", "database"],
        "additionalProperties": false,
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["mysql", "hive"]
          },
          "driver": { "type": "string", "minLength": 1 },
          "host": { "type": "string", "minLength": 1 },
          "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
          "user": { "type": "string", "minLength": 1 },
          "password": { "type": "string" },
          "database": { "$ref": "#/$defs/sqlIdentifier" }
        }
      }
    },
    "query_policy": {
      "type": "object",
      "required": [
        "default_limit",
        "max_limit",
        "table_preview_limit",
        "require_time_or_bbox_filter"
      ],
      "additionalProperties": false,
      "properties": {
        "default_limit": { "type": "integer", "minimum": 1 },
        "max_limit": {
          "anyOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "null" }
          ]
        },
        "table_preview_limit": { "type": "integer", "minimum": 1 },
        "require_time_or_bbox_filter": { "type": "boolean" }
      }
    },
    "server": {
      "type": "object",
      "required": ["default_command", "host", "port", "debug", "kill_port_if_busy"],
      "additionalProperties": false,
      "properties": {
        "default_command": {
          "type": "string",
          "enum": ["serve"]
        },
        "host": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "debug": { "type": "boolean" },
        "kill_port_if_busy": { "type": "boolean" }
      }
    },
    "rendering": {
      "type": "object",
      "required": ["hardware_acceleration", "allow_webgl", "allow_webgpu", "min_webgl_rows"],
      "additionalProperties": false,
      "properties": {
        "hardware_acceleration": {
          "type": "string",
          "enum": ["auto", "off", "force"]
        },
        "allow_webgl": { "type": "boolean" },
        "allow_webgpu": { "type": "boolean" },
        "min_webgl_rows": { "type": "integer", "minimum": 1 }
      }
    },
    "test_data_bootstrap": {
      "type": "object",
      "required": ["enabled", "auto_on_serve", "manifest"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "auto_on_serve": { "type": "boolean" },
        "manifest": { "type": "string", "minLength": 1 }
      }
    },
    "default_dataset": {
      "$ref": "#/$defs/sqlIdentifier"
    },
    "live": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ais": {
          "type": "object",
          "required": [
            "enabled",
            "connection",
            "database",
            "table",
            "time_column",
            "lat_column",
            "lon_column",
            "mmsi_column",
            "max_age_minutes",
            "limit"
          ],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "provider": {
              "type": "string",
              "enum": ["mysql", "aisstream", "aishub_polling"]
            },
            "api_key": { "type": "string" },
            "api_key_fingerprint": { "type": "string" },
            "stream_url": { "type": "string", "minLength": 1 },
            "aishub_username": { "type": "string" },
            "aishub_url": { "type": "string", "minLength": 1 },
            "filter_message_types": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            },
            "snapshot_interval_ms": { "type": "integer", "minimum": 250 },
            "stream_cache_limit": { "type": "integer", "minimum": 1 },
            "ingest_enabled": { "type": "boolean" },
            "ingest_reconnect_seconds": { "type": "integer", "minimum": 3 },
            "ingest_status_report_seconds": { "type": "integer", "minimum": 3 },
            "ingest_flush_seconds": { "type": "number", "minimum": 0.25 },
            "ingest_batch_size": { "type": "integer", "minimum": 1 },
            "ingest_auto_create_table": { "type": "boolean" },
            "ingest_meta_table": { "$ref": "#/$defs/sqlIdentifier" },
            "collector_config_path": { "type": "string", "minLength": 1 },
            "connection": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "host": { "type": "string", "minLength": 1 },
                "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
                "user": { "type": "string", "minLength": 1 },
                "password": { "type": "string" }
              }
            },
            "database": { "$ref": "#/$defs/sqlIdentifier" },
            "table": { "$ref": "#/$defs/sqlIdentifier" },
            "time_column": { "$ref": "#/$defs/sqlIdentifier" },
            "lat_column": { "$ref": "#/$defs/sqlIdentifier" },
            "lon_column": { "$ref": "#/$defs/sqlIdentifier" },
            "mmsi_column": { "$ref": "#/$defs/sqlIdentifier" },
            "speed_column": { "$ref": "#/$defs/sqlIdentifier" },
            "course_column": { "$ref": "#/$defs/sqlIdentifier" },
            "heading_column": { "$ref": "#/$defs/sqlIdentifier" },
            "name_column": { "$ref": "#/$defs/sqlIdentifier" },
            "source_column": { "$ref": "#/$defs/sqlIdentifier" },
            "include_sources": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "max_age_minutes": { "type": "integer", "minimum": 1 },
            "limit": {
              "oneOf": [
                { "type": "integer", "minimum": 1 },
                { "type": "string", "enum": ["max", "all", "unbounded"] }
              ]
            }
          }
        }
      }
    },
    "datasets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "label",
          "duckdb_source_table",
          "mysql_table",
          "time_column",
          "lat_column",
          "lon_column",
          "id_column",
          "display_columns",
          "metric_columns",
          "category_columns"
        ],
        "additionalProperties": false,
        "properties": {
          "label": { "type": "string", "minLength": 1 },
          "backend": {
            "type": "string",
            "enum": ["mysql", "hive"]
          },
          "connection_ref": { "$ref": "#/$defs/sqlIdentifier" },
          "duckdb_source_table": {
            "type": "string",
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\.[A-Za-z_][A-Za-z0-9_]*)?$"
          },
          "mysql_table": { "$ref": "#/$defs/sqlIdentifier" },
          "table": { "$ref": "#/$defs/sqlIdentifier" },
          "time_column": { "$ref": "#/$defs/sqlIdentifier" },
          "lat_column": { "$ref": "#/$defs/sqlIdentifier" },
          "lon_column": { "$ref": "#/$defs/sqlIdentifier" },
          "id_column": { "$ref": "#/$defs/sqlIdentifier" },
          "display_columns": {
            "type": "array",
            "minItems": 1,
            "items": { "$ref": "#/$defs/sqlIdentifier" }
          },
          "metric_columns": {
            "type": "array",
            "items": { "$ref": "#/$defs/sqlIdentifier" }
          },
          "category_columns": {
            "type": "array",
            "items": { "$ref": "#/$defs/sqlIdentifier" }
          }
        }
      }
    }
  },
  "$defs": {
    "sqlIdentifier": {
      "type": "string",
      "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
    }
  }
}
