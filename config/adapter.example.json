{
  "sql_backend": {
    "kind": "mysql",
    "driver": "pymysql"
  },
  "mysql": {
    "host": "127.0.0.1",
    "port": 3307,
    "user": "root",
    "password": "fishery123",
    "database": "ocean_fishery"
  },
  "default_connection_ref": "local_mysql",
  "connections": {
    "local_mysql": {
      "kind": "mysql",
      "driver": "pymysql",
      "host": "127.0.0.1",
      "port": 3307,
      "user": "root",
      "password": "fishery123",
      "database": "ocean_fishery"
    },
    "class_hive": {
      "kind": "hive",
      "driver": "placeholder",
      "host": "hive-server.local",
      "port": 10000,
      "user": "hive",
      "password": "env:HIVE_PASSWORD",
      "database": "ocean_warehouse"
    }
  },
  "query_policy": {
    "default_limit": 5000,
    "max_limit": 100000,
    "table_preview_limit": 300,
    "require_time_or_bbox_filter": true
  },
  "server": {
    "default_command": "serve",
    "host": "127.0.0.1",
    "port": 5057,
    "debug": false,
    "kill_port_if_busy": true
  },
  "rendering": {
    "hardware_acceleration": "auto",
    "allow_webgl": true,
    "allow_webgpu": false,
    "min_webgl_rows": 1
  },
  "test_data_bootstrap": {
    "enabled": true,
    "auto_on_serve": true,
    "manifest": "config/test_data.example.json"
  },
  "overlays": {
    "eez": {
      "enabled": true,
      "provider": "postgis",
      "full_gpkg_path": "data/eez/eez_v12.gpkg",
      "source": {
        "kind": "remote_gpkg_zip",
        "url": "https://www.marineregions.org/download_file.php?name=World_EEZ_v12_20231025_gpkg.zip",
        "source_page": "https://www.marineregions.org/downloads.php",
        "version": "v12_20231025",
        "archive_path": "data/eez/World_EEZ_v12_20231025_gpkg.zip",
        "cache_path": "data/eez/eez_v12.gpkg",
        "remove_archive": false
      },
      "auto_download": true,
      "auto_import": true,
      "auto_replace": true,
      "gpkg_table": "eez_v12",
      "gpkg_geometry_column": "geom",
      "force_full": false,
      "tile_cache_max": 2048,
      "postgis": {
        "host": "127.0.0.1",
        "port": 5433,
        "user": "postgres",
        "password": "spatial123",
        "database": "ocean_spatial",
        "table": "eez_v12",
        "tile_table": "eez_v12_tile",
        "boundary_table": "eez_v12_boundary",
        "geometry_column": "geom",
        "mvt_layer": "eez"
      }
    }
  },
  "live": {
    "ais": {
      "enabled": false,
      "provider": "mysql",
      "api_key": "env:AISSTREAM_API_KEY",
      "api_key_fingerprint": "",
      "stream_url": "wss://stream.aisstream.io/v0/stream",
      "aishub_username": "env:AISHUB_USERNAME",
      "aishub_url": "https://data.aishub.net/ws.php",
      "filter_message_types": [
        "PositionReport",
        "StandardClassBPositionReport",
        "ExtendedClassBPositionReport"
      ],
      "snapshot_interval_ms": 1000,
      "stream_cache_limit": 10000,
      "ingest_enabled": true,
      "ingest_reconnect_seconds": 30,
      "ingest_status_report_seconds": 30,
      "ingest_flush_seconds": 1.0,
      "ingest_batch_size": 250,
      "ingest_auto_create_table": true,
      "ingest_meta_table": "ais_ingest_meta",
      "collector_config_path": "config/ais_collector.local.json",
      "connection": {
        "host": "127.0.0.1",
        "port": 3306,
        "user": "root",
        "password": "env:RRKAL_AIS_MYSQL_PASSWORD"
      },
      "database": "ocean_fishery",
      "table": "ais_latest",
      "time_column": "event_time",
      "lat_column": "lat",
      "lon_column": "lon",
      "mmsi_column": "mmsi",
      "speed_column": "sog",
      "course_column": "cog",
      "heading_column": "heading",
      "name_column": "vessel_name",
      "source_column": "source",
      "include_sources": [
        "aisstream"
      ],
      "max_age_minutes": 60,
      "limit": "max"
    }
  },
  "default_dataset": "gfw_full",
  "datasets": {
    "gfw_full": {
      "label": "GFW January 2024 grid",
      "backend": "mysql",
      "connection_ref": "local_mysql",
      "duckdb_source_table": "main.gold_grid",
      "mysql_table": "gold_grid",
      "table": "gold_grid",
      "time_column": "obs_date",
      "lat_column": "lat",
      "lon_column": "lon",
      "id_column": "grid_id",
      "display_columns": [
        "obs_date",
        "grid_id",
        "lat",
        "lon",
        "fish_sum",
        "fish_ratio",
        "vessels",
        "dominant_flag",
        "dominant_gear",
        "sst",
        "chlor_a",
        "kd490",
        "nflh"
      ],
      "metric_columns": [
        "fish_sum",
        "fish_ratio",
        "vessels",
        "sst",
        "chlor_a",
        "kd490",
        "nflh"
      ],
      "category_columns": [
        "dominant_flag",
        "dominant_gear"
      ]
    }
  }
}
