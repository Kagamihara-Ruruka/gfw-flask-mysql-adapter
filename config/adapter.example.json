{
  "sql_backend": {
    "kind": "mysql",
    "driver": "pymysql"
  },
  "mysql": {
    "host": "127.0.0.1",
    "port": 3307,
    "user": "root",
    "password": "fishery123",
    "database": "ocean_fishery"
  },
  "query_policy": {
    "default_limit": 5000,
    "max_limit": 100000,
    "table_preview_limit": 300,
    "require_time_or_bbox_filter": true
  },
  "server": {
    "default_command": "serve",
    "host": "127.0.0.1",
    "port": 5057,
    "debug": false,
    "kill_port_if_busy": true
  },
  "test_data_bootstrap": {
    "enabled": true,
    "auto_on_serve": true,
    "manifest": "config/test_data.example.json"
  },
  "overlays": {
    "eez": {
      "enabled": true,
      "provider": "postgis",
      "full_gpkg_path": "data/eez_v12.gpkg",
      "gpkg_table": "eez_v12",
      "gpkg_geometry_column": "geom",
      "force_full": false,
      "postgis": {
        "host": "127.0.0.1",
        "port": 5433,
        "user": "postgres",
        "password": "spatial123",
        "database": "ocean_spatial",
        "table": "eez_v12",
        "tile_table": "eez_v12_tile",
        "boundary_table": "eez_v12_boundary",
        "geometry_column": "geom",
        "mvt_layer": "eez"
      }
    }
  },
  "live": {
    "ais": {
      "enabled": false,
      "connection": {
        "host": "127.0.0.1",
        "port": 3306,
        "user": "root",
        "password": "env:RRKAL_AIS_MYSQL_PASSWORD"
      },
      "database": "ocean_fishery",
      "table": "ais_latest",
      "time_column": "event_time",
      "lat_column": "lat",
      "lon_column": "lon",
      "mmsi_column": "mmsi",
      "speed_column": "sog",
      "course_column": "cog",
      "heading_column": "heading",
      "name_column": "vessel_name",
      "max_age_minutes": 60,
      "limit": "max"
    }
  },
  "default_dataset": "gfw_full",
  "datasets": {
    "gfw_full": {
      "label": "GFW January 2024 grid",
      "duckdb_source_table": "main.gold_grid",
      "mysql_table": "gold_grid",
      "time_column": "obs_date",
      "lat_column": "lat",
      "lon_column": "lon",
      "id_column": "grid_id",
      "display_columns": [
        "obs_date",
        "grid_id",
        "lat",
        "lon",
        "fish_sum",
        "fish_ratio",
        "vessels",
        "dominant_flag",
        "dominant_gear",
        "sst",
        "chlor_a",
        "kd490",
        "nflh"
      ],
      "metric_columns": [
        "fish_sum",
        "fish_ratio",
        "vessels",
        "sst",
        "chlor_a",
        "kd490",
        "nflh"
      ],
      "category_columns": [
        "dominant_flag",
        "dominant_gear"
      ]
    }
  }
}
