{
  "schema": "rrkal.adapter.runtime_json.v1",
  "role": "runtime_json",
  "description": "Runtime settings only. Source routes are selected by config/state/router_manifest.local.json.",
  "query_policy": {
    "default_limit": null,
    "max_limit": null,
    "table_preview_limit": 300,
    "require_time_or_bbox_filter": true,
    "network_concurrency": 6,
    "background_network_concurrency": 3,
    "batch_max_operations": 3,
    "snapshot_cache_max_rows": 800000
  },
  "server": {
    "default_command": "serve",
    "host": "127.0.0.1",
    "port": 5057,
    "debug": false,
    "kill_port_if_busy": true
  },
  "rendering": {
    "hardware_acceleration": "auto",
    "allow_webgl": true,
    "allow_webgpu": false,
    "min_webgl_rows": 1
  }
}
