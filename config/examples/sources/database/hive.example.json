{
  "schema": "rrkal.adapter.database.v1",
  "role": "database",
  "name": "spark_thrift",
  "description": "PyHive source route for a Spark Thrift sampled-grid read model.",
  "sql_backend": {
    "kind": "hive",
    "driver": "pyhive"
  },
  "connections": {
    "spark_thrift": {
      "kind": "hive",
      "driver": "pyhive",
      "host": "dtadm",
      "port": 10000,
      "user": "bigred",
      "username": "bigred",
      "auth": "NONE",
      "catalog": "lake",
      "schema": "ocean"
    }
  },
  "tables": {
    "gold_map_metric": "lake.ocean.gold_map_metric"
  },
  "defaults": {
    "start_date": "2022-01-01",
    "end_date": "2024-12-31",
    "aoi": "taiwan",
    "product": "SST",
    "metric": "sea_temperature",
    "resolution": 4,
    "heatmap_limit": 20000
  }
}
