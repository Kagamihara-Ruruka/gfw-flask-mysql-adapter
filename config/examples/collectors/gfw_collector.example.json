{
  "source": {
    "kind": "duckdb",
    "duckdb_path": "data/release_stage/gfw_full.duckdb",
    "source_table": "main.gold_grid"
  },
  "sink": {
    "kind": "mysql",
    "adapter_config": "config/runtime/adapter.local.json",
    "dataset_id": "gfw_full",
    "replace": true,
    "chunk_size": 5000
  },
  "storage_note": {
    "mysql_container_data_directory": "D:/RRKAL_tools/gfw_mysql_data",
    "boundary": "The collector owns source files and SQL loading. The consumer app only reads SQL."
  }
}
