{
  "sql_backend": {
    "kind": "mysql",
    "driver": "pymysql"
  },
  "default_connection_ref": "ais_mysql",
  "connections": {
    "ais_mysql": {
      "kind": "mysql",
      "driver": "pymysql",
      "host": "127.0.0.1",
      "port": 3306,
      "user": "root",
      "password": "env:RRKAL_AIS_MYSQL_PASSWORD",
      "database": "BDDE38No1"
    }
  },
  "query_policy": {
    "default_limit": 5000,
    "max_limit": 100000,
    "table_preview_limit": 300,
    "require_time_or_bbox_filter": true
  },
  "server": {
    "default_command": "serve",
    "host": "127.0.0.1",
    "port": 5057,
    "debug": false,
    "kill_port_if_busy": true
  },
  "live": {
    "ais": {
      "enabled": true,
      "provider": "aisstream",
      "api_key": "env:AISSTREAM_API_KEY",
      "api_key_fingerprint": "",
      "stream_url": "wss://stream.aisstream.io/v0/stream",
      "filter_message_types": [
        "PositionReport",
        "StandardClassBPositionReport",
        "ExtendedClassBPositionReport"
      ],
      "ingest_enabled": true,
      "ingest_reconnect_seconds": 30,
      "ingest_status_report_seconds": 30,
      "ingest_flush_seconds": 1.0,
      "ingest_batch_size": 250,
      "ingest_auto_create_table": true,
      "ingest_meta_table": "ais_ingest_meta",
      "ingest_data_directory": "D:/RRKAL_tools/mysql_ais_data",
      "collector_config_path": "config/ais_collector.local.json",
      "snapshot_enabled": true,
      "snapshot_table": "ais_hourly_snapshots",
      "snapshot_retention_days": 31,
      "snapshot_interval_hours": 1,
      "snapshot_window_hours": 1,
      "connection_ref": "ais_mysql",
      "database": "BDDE38No1",
      "table": "ais_positions",
      "time_column": "event_time",
      "lat_column": "lat",
      "lon_column": "lon",
      "mmsi_column": "mmsi",
      "speed_column": "sog",
      "course_column": "cog",
      "heading_column": "heading",
      "name_column": "vessel_name",
      "source_column": "source",
      "include_sources": [
        "aisstream"
      ],
      "max_age_minutes": 1440,
      "limit": "max"
    }
  },
  "default_dataset": "collector_contract_dummy",
  "datasets": {
    "collector_contract_dummy": {
      "label": "AIS collector config validation dummy",
      "backend": "mysql",
      "connection_ref": "ais_mysql",
      "mysql_table": "ais_positions",
      "table": "ais_positions",
      "time_column": "event_time",
      "lat_column": "lat",
      "lon_column": "lon",
      "id_column": "mmsi",
      "display_columns": [
        "event_time",
        "mmsi",
        "lat",
        "lon",
        "sog",
        "cog",
        "heading",
        "vessel_name",
        "source"
      ],
      "metric_columns": [
        "sog",
        "cog",
        "heading"
      ],
      "category_columns": [
        "source"
      ]
    }
  }
}
