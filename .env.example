# Copy this file to .env and replace every change-me value before using Docker Compose.
PRESENTATION_POSTGRES_PASSWORD=change-me
PRESENTATION_HTTP_PORT=5185
PRESENTATION_DEVELOPER_PORT=5186
PRESENTATION_IMAGE=bdde38-presentation:local

# Generic local dependency profile (docker-compose.yml).
MYSQL_ROOT_PASSWORD=change-me
MYSQL_DATA_PATH=D:/replace-with-your/mysql-data
EEZ_POSTGRES_PASSWORD=change-me
