{
  "schema": "rrkal.ais.collector_handoff.v1",
  "role": "upstream_ais_collector",
  "provider": "aisstream",
  "api_key": "env:AISSTREAM_API_KEY",
  "stream_url": "wss://stream.aisstream.io/v0/stream",
  "filter_message_types": [
    "PositionReport",
    "StandardClassBPositionReport",
    "ExtendedClassBPositionReport",
    "ShipStaticData",
    "StaticDataReport"
  ],
  "ingest": {
    "enabled": true,
    "reconnect_seconds": 30,
    "status_report_seconds": 30,
    "flush_seconds": 1.0,
    "batch_size": 250,
    "auto_create_table": true,
    "meta_table": "ais_ingest_meta",
    "data_directory": "data/mysql_ais_data",
    "snapshot_enabled": true,
    "snapshot_table": "ais_hourly_snapshots",
    "snapshot_retention_days": 31,
    "snapshot_interval_hours": 1,
    "snapshot_window_hours": 1
  },
  "sql": {
    "connection": {
      "host": "127.0.0.1",
      "port": 3306,
      "user": "root",
      "password": "env:RRKAL_AIS_MYSQL_PASSWORD"
    },
    "database": "BDDE38No1",
    "table": "ais_positions",
    "time_column": "event_time",
    "static_time_column": "static_event_time",
    "received_time_column": "received_at",
    "lat_column": "lat",
    "lon_column": "lon",
    "mmsi_column": "mmsi",
    "speed_column": "sog",
    "course_column": "cog",
    "heading_column": "heading",
    "name_column": "vessel_name",
    "source_column": "source",
    "include_sources": ["aisstream"],
    "max_age_minutes": 1440,
    "limit": "max"
  },
  "note": "Example only. Do not commit real API keys or local passwords."
}
